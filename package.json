{
  "name": "chreol-change-money",
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:sw": "esbuild sw.ts --bundle --outfile=public/sw.js --format=esm --minify",
    "build:all": "npm run build:sw && npm run build",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "seo:audit": "lighthouse http://localhost:5173 --view"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "postcss": "^8.5.12",
    "pwa-asset-generator": "^8.1.4",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "workbox-core": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0"
  }
}
